{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad"],
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "API base URL (usually same as your domain)"
    }
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
